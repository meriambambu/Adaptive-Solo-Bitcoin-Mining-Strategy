# ─── Braiins Hash Power API ───────────────────────────────────────────────────
# Generate in your Braiins account → Settings → API Keys
BRAIINS_API_KEY=your_api_key_here

# ─── Braiins Solo Pool ────────────────────────────────────────────────────────
# Your BTC payout address — used server-side only for solo.braiins.com stats
SOLO_WALLET=your_btc_address_here

# ─── Recent Blocks feed ───────────────────────────────────────────────────────
# Base URL for the mempool.space "recent blocks" proxy. Defaults to the public
# host below. If mempool.space is geo-blocked on your network, point this at a
# self-hosted or mirror instance instead.
MEMPOOL_BASE=https://mempool.space

# ─── Adaptive Strategy ────────────────────────────────────────────────────────
# Pure P_N tracking: target price = the Nth cheapest matched bid in the order book.
# RAISE to P_N when below, LOWER to P_N when above, HOLD when equal. No offsets/guesses.

# Target rank — P_N is the Nth cheapest bid that is actually receiving hashrate
TOP_N=5

# BTC/EH/day — hard cap, never bid above this
MAX_BID_PRICE=0.60

# BTC/EH/day — floor, never bid below this
MIN_BID_PRICE=0.10

# Seconds to wait between LOWER edits on the same bid (API rate-limit guard)
LOWER_COOLDOWN=300

# Seconds between full strategy evaluation cycles (minimum 30)
POLL_INTERVAL=60

# Seconds between fast rank checks — only raises, no lowers (minimum 10)
RANK_CHECK_INTERVAL=15

# Master switch: true | false
STRATEGY_ENABLED=true

# ─── App ──────────────────────────────────────────────────────────────────────
# Port for the FastAPI backend
PORT=8000

# Frontend origin for CORS (change if hosting separately)
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file path
DATABASE_URL=sqlite:///./data/mining.sqlite

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
