# ─── Braiins Hash Power API ───────────────────────────────────────────────────
# Generate in your Braiins account → Settings → API Keys
BRAIINS_API_KEY=your_api_key_here

# ─── Adaptive Strategy ────────────────────────────────────────────────────────
# Stay in the cheapest TOP_N bids in the order book
TOP_N=5

# BTC/EH/day — never bid above this (hard safety cap)
MAX_BID_PRICE=0.60

# BTC/EH/day — never bid below this floor
MIN_BID_PRICE=0.10

# How far above P_N before we lower our price (prevents flapping)
UPPER_BUFFER=0.01

# How far below P_N to target when lowering
LOWER_MARGIN=0.005

# Step size when raising price
PRICE_STEP=0.005

# Seconds between strategy evaluation cycles (minimum 30)
POLL_INTERVAL=60

# Master switch: true | false
STRATEGY_ENABLED=true

# ─── App ──────────────────────────────────────────────────────────────────────
# Port for the FastAPI backend
PORT=8000

# Frontend origin for CORS (change if hosting separately)
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file path
DATABASE_URL=sqlite:///./data/mining.sqlite

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
